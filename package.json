{
  "name": "solar-3d",
  "version": "2.0.0",
  "private": true,
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @solar/backend dev\" \"pnpm --filter @solar/frontend dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "download-textures": "node scripts/download-textures.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
